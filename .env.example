# Copy to .env and fill in. .env is gitignored — never commit real values.
# Supabase project (anon key is a public/publishable key, safe in the client).
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google OAuth "Desktop app" (installed) client. Read only by the Rust build
# (build.rs → env!) and baked into the binary, never shipped in the JS bundle.
# Desktop OAuth secrets are not treated as confidential by Google.
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-desktop-client-secret
